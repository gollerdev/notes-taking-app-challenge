# Base URL for the backend API (browser-facing).
# The frontend appends /api/v1 to this value.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API URL for server-component fetches inside the Docker container.
# Uses the compose service name so Docker's network resolves the backend.
# Never use NEXT_PUBLIC_API_URL for server-side fetches — localhost inside
# the container resolves to the container itself, not the backend service.
INTERNAL_API_URL=http://web:8000
