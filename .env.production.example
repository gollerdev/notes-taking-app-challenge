# Production environment file — lives on the VPS only (gitignored).
# Copy and fill in real values:  cp .env.production.example .env.production

# Domain (used by Caddy for auto-TLS and by ALLOWED_HOSTS / CORS)
DOMAIN=notes.yourdomain.com

# Django
SECRET_KEY=generate-a-real-secret-key
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=notes.yourdomain.com
CORS_ALLOWED_ORIGINS=https://notes.yourdomain.com

# PostgreSQL
DB_NAME=notes
DB_USER=notes
DB_PASSWORD=change-me-to-a-strong-password
DB_HOST=db
DB_PORT=5432

# Frontend — browser-facing URL (must match the domain with https)
NEXT_PUBLIC_API_URL=https://notes.yourdomain.com

# Frontend — container-internal URL for server-component fetches
INTERNAL_API_URL=http://web:8000
