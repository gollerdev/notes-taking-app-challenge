# Django
# Generate a new key for real deployments, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
# DB_HOST defaults to the compose service name so the app resolves Postgres
# inside the Docker network with no extra configuration.
DB_NAME=notes
DB_USER=notes
DB_PASSWORD=notes
DB_HOST=db
DB_PORT=5432
