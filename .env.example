# Root environment file — single source of truth for `docker compose up`.
# Copy to `.env` and adjust values for your machine:  cp .env.example .env
#
# Consumed by:
#   - the `db` service     -> POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD (via DB_* below)
#   - the `web` service     -> Django settings (env_file)
#   - the `frontend` service -> NEXT_PUBLIC_API_URL

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — shared by the db container and the Django app.
# DB_HOST is the compose service name so the app resolves Postgres inside the
# Docker network. DB_PORT is the in-network port (5432), not the host mapping.
DB_NAME=notes
DB_USER=notes
DB_PASSWORD=notes
DB_HOST=db
DB_PORT=5432

# Frontend — browser-facing URL. The frontend appends /api/v1 to this value.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend — container-internal URL for server-component fetches (Docker network).
# Resolves the backend via the compose service name; never use localhost here.
INTERNAL_API_URL=http://web:8000
